{
  "name": "@resuave/texteditor",
  "version": "0.1.0",
  "description": "A reusable rich text editor component built with Tiptap for React applications.",
  "homepage": "https://github.com/Restu-Averian/-resuave-texteditor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Restu-Averian/-resuave-texteditor.git"
  },
  "bugs": {
    "url": "https://github.com/Restu-Averian/-resuave-texteditor/issues"
  },
  "author": {
    "name": "Restu-Averian",
    "url": "https://github.com/Restu-Averian"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css",
    "./dist/style.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "build:docs": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "npm run build:lib && npm run pack:dry"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@tiptap/react": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/extension-list": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "prettier": "^3.9.4",
    "radix-ui": "^1.6.1",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fzf": "^0.5.2",
    "globals": "^17.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "react-shiki": "^0.10.1",
    "shadcn": "^4.12.0",
    "shadcn-ui": "^0.9.5",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.3"
  },
  "keywords": [
    "react",
    "tiptap",
    "text-editor",
    "rich-text-editor",
    "wysiwyg",
    "editor"
  ],
  "license": "MIT"
}
